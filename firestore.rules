rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: read/write by owner only
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Deletion via Cloud Function only
    }

    // Plates: read by owner, write via Cloud Functions only
    match /plates/{plateHash} {
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow write: if false; // Write via Cloud Functions only
    }

    // Reports: create by authenticated users, read by plate owner
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Read via Cloud Functions for notification
      allow update, delete: if false;
    }

    // AbuseTracking: Cloud Functions only
    match /abuseTracking/{userId} {
      allow read, write: if false;
    }
  }
}
